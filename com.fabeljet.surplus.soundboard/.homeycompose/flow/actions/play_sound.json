{
  "id": "play_sound",
  "title": {
    "en": "Play a sound"
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=soundboard"
    },
    {
      "name": "sound_id",
      "type": "text",
      "placeholder": {
        "en": "Sound ID"
      }
    },
    {
      "name": "volume",
      "type": "number",
      "min": 0,
      "max": 400,
      "step": 1,
      "placeholder": {
        "en": "100"
      }
    }
  ]
}
