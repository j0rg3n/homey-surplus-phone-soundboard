{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.fabeljet.surplus.soundboard",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Surplus Soundboard"
  },
  "description": {
    "en": "Advanced sound board using surplus mobile devices"
  },
  "category": [
    "music"
  ],
  "brandColor": "#6C5CE7",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Jørgen Seland",
    "email": "jorgen@fabeljet.com"
  },
  "flow": {
    "triggers": [
      {
        "id": "sound_done",
        "title": {
          "en": "A sound finished"
        },
        "titleFormatted": {
          "en": "A sound finished on [[device]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=soundboard"
          }
        ],
        "tokens": [
          {
            "name": "sound_name",
            "type": "string",
            "title": {
              "en": "Sound name"
            }
          },
          {
            "name": "handle",
            "type": "string",
            "title": {
              "en": "Handle"
            }
          },
          {
            "name": "reason",
            "type": "string",
            "title": {
              "en": "Reason"
            }
          }
        ]
      },
      {
        "id": "sound_started",
        "title": {
          "en": "A sound started playing"
        },
        "titleFormatted": {
          "en": "A sound started playing on [[device]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=soundboard"
          }
        ],
        "tokens": [
          {
            "name": "sound_name",
            "type": "string",
            "title": {
              "en": "Sound name"
            }
          },
          {
            "name": "handle",
            "type": "string",
            "title": {
              "en": "Handle"
            }
          },
          {
            "name": "duration_ms",
            "type": "number",
            "title": {
              "en": "Duration (ms)"
            }
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "is_playing",
        "title": {
          "en": "Soundboard is currently playing"
        },
        "titleFormatted": {
          "en": "Soundboard is currently playing"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=soundboard"
          }
        ]
      },
      {
        "id": "sound_is_playing",
        "title": {
          "en": "A sound is currently playing"
        },
        "titleFormatted": {
          "en": "[[sound]] is currently playing"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=soundboard"
          },
          {
            "name": "sound",
            "type": "autocomplete",
            "placeholder": {
              "en": "Select a sound…"
            }
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "play_sound",
        "title": {
          "en": "Play a sound"
        },
        "titleFormatted": {
          "en": "Play [[sound]] at volume [[volume]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=soundboard"
          },
          {
            "name": "sound",
            "type": "autocomplete",
            "placeholder": {
              "en": "Search sounds…"
            }
          },
          {
            "name": "volume",
            "type": "number",
            "min": 0,
            "max": 400,
            "step": 1,
            "placeholder": {
              "en": "100"
            }
          }
        ]
      },
      {
        "id": "set_volume",
        "title": {
          "en": "Set global volume"
        },
        "titleFormatted": {
          "en": "Set volume to [[volume]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=soundboard"
          },
          {
            "name": "volume",
            "type": "number",
            "min": 0,
            "max": 400,
            "step": 1,
            "placeholder": {
              "en": "100"
            }
          }
        ]
      },
      {
        "id": "stop_all",
        "title": {
          "en": "Stop all sounds"
        },
        "titleFormatted": {
          "en": "Stop all sounds"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=soundboard"
          }
        ]
      },
      {
        "id": "stop_sound",
        "title": {
          "en": "Stop a sound"
        },
        "titleFormatted": {
          "en": "Stop sound [[handle]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=soundboard"
          },
          {
            "name": "handle",
            "type": "text",
            "placeholder": {
              "en": "Handle tag from play_sound"
            }
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Soundboard Device"
      },
      "class": "speaker",
      "capabilities": [
        "speaker_playing"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "pair": [
        {
          "id": "start"
        }
      ],
      "id": "soundboard"
    }
  ]
}