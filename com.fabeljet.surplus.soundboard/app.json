{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.fabeljet.surplus.soundboard",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Surplus Soundboard"
  },
  "description": {
    "en": "Advanced sound board using surplus mobile devices"
  },
  "category": [
    "music"
  ],
  "brandColor": "#6C5CE7",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Jørgen Seland",
    "email": "jorgen@fabeljet.com"
  },
  "drivers": [
    {
      "id": "soundboard",
      "name": {
        "en": "Soundboard Device"
      },
      "class": "speaker",
      "capabilities": [
        "speaker_playing"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "pair": [
        {
          "id": "start",
          "navigation": {
            "next": "done"
          }
        }
      ]
    }
  ],
  "flow": {
    "actions": [
      {
        "id": "play_sound",
        "title": {
          "en": "Play a sound"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=soundboard"
          },
          {
            "name": "sound_id",
            "type": "text",
            "placeholder": {
              "en": "Sound ID"
            }
          },
          {
            "name": "volume",
            "type": "number",
            "min": 0,
            "max": 400,
            "step": 1,
            "placeholder": {
              "en": "100"
            }
          }
        ]
      }
    ]
  }
}
